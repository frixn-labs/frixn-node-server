# Server Port
PORT=5000

# API Security Secret (Used for protecting /api/email/* endpoints)
# Replace this with a strong, randomly generated key in production
API_SECRET=your_api_secret_key

# Supabase Configurations
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Resend API Configuration
RESEND_API_KEY=re_your_resend_api_key

# Rate Limiting Configurations (Email Endpoint)
RATE_LIMIT_EMAIL_WINDOW_MS=60000
RATE_LIMIT_EMAIL_MAX=20

